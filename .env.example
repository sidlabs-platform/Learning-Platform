# ==============================================================================
# Learning Platform — Environment Variable Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# GitHub Models API (AI Content Generation)
# Required for AI-assisted course content generation (COMP-003).
# ------------------------------------------------------------------------------

# API key for authenticating with the GitHub Models endpoint.
# Obtain from GitHub Settings → Developer settings → Personal access tokens.
GITHUB_MODELS_API_KEY=your-github-models-api-key-here

# Base URL for the GitHub Models API endpoint.
# Default: https://models.inference.ai.azure.com
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com

# ------------------------------------------------------------------------------
# Application Security
# Required for JWT token signing and CORS configuration.
# ------------------------------------------------------------------------------

# Secret key used to sign and verify JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be a long, random string. Rotate periodically in production.
SECRET_KEY=change-me-generate-a-strong-random-secret-key

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# SQLAlchemy async database URL.
# For local development with SQLite:
DATABASE_URL=sqlite+aiosqlite:///./learning_platform.db

# ------------------------------------------------------------------------------
# Application Runtime
# ------------------------------------------------------------------------------

# Runtime environment. Controls debug logging, error detail levels, etc.
# Values: development | staging | production
ENVIRONMENT=development

# ------------------------------------------------------------------------------
# AI Generation Behaviour
# ------------------------------------------------------------------------------

# Maximum number of retry attempts for failed GitHub Models API requests.
# Uses exponential backoff between retries.
# Default: 3
AI_MAX_RETRIES=3

# Timeout in seconds for each GitHub Models API request.
# AI generation may take longer than standard API calls.
# Default: 60
AI_REQUEST_TIMEOUT_SECONDS=60

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# For local development: http://localhost:8000
# For production: set to your actual frontend domain(s).
# Example: https://learning.example.com,https://www.learning.example.com
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
