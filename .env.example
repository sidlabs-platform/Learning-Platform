# ──────────────────────────────────────────────
# Learning Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# ── GitHub Models API (required for AI content generation) ──────────────────
# Your GitHub personal access token with models:read scope.
GITHUB_MODELS_API_KEY=your-github-pat-here

# Base URL for the GitHub Models inference endpoint.
# Default: https://models.inference.ai.azure.com
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com

# ── Security ─────────────────────────────────────────────────────────────────
# A long, random secret used to sign JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-secure-random-value

# Minutes before an issued access token expires (default: 60).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite async connection URL.
# Default creates learning_platform.db in the project root.
DATABASE_URL=sqlite+aiosqlite:///./learning_platform.db

# ── Application ───────────────────────────────────────────────────────────────
# Runtime environment: development | production | testing
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins (no trailing slash).
# Example: http://localhost:8000,https://your-domain.com
CORS_ORIGINS=http://localhost:8000

# ── AI Generation Resilience ──────────────────────────────────────────────────
# Maximum number of retry attempts for GitHub Models API calls (default: 3).
AI_MAX_RETRIES=3

# Timeout in seconds for each GitHub Models API request (default: 60).
AI_REQUEST_TIMEOUT_SECONDS=60
